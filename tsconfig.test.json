{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "tests-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "experimentalDecorators": true,
    "baseUrl": "."
  },
  "include": [
    "tests/**/*.ts",
    "src/**/*.ts"
  ]
}

